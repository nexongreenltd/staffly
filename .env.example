# ============================================================
# Staffly – Environment Variables
# Copy to .env and fill in real values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=hrm_user
DB_PASS=hrm_secure_password
DB_NAME=terraprime_hrm
DB_SSL=false
DB_LOGGING=false

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=

# ── Backend ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# ── Worker ───────────────────────────────────────────────────
SCHEDULER_INTERVAL_MS=300000     # 5 minutes
DEVICE_TIMEOUT_MS=10000          # 10 seconds
MAX_DEVICE_RETRIES=3
LOG_LEVEL=info

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
